/* ------------------------------
   THE FACTORY BORDERROUGE
   DESIGN FUTURISTE PREMIUM
   FULL BLACK + NÉON + ANIMATIONS
--------------------------------*/

:root {
  --noir: #000000;
  --noir2: #000000;
  --rouge: #ff2e2e;
  --rouge-glow: #ff2e2ebb;
  --blanc: #ffffff;
  --gris: #cfcfcf;
  --radius: 14px;
}

/* LOADER FUTURISTE */
#loader {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: var(--noir);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 2000;
  transition: 0.5s;
}

.loader-ring {
  width: 80px;
  height: 80px;
  border: 4px solid transparent;
  border-top: 4px solid var(--rouge);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 15px;
}

#loader p {
  font-size: 18px;
  letter-spacing: 4px;
  color: var(--rouge);
  text-shadow: 0 0 20px var(--rouge-glow);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* TITRES NÉON PULSÉS */
.neon-title {
  animation: pulse 1.8s infinite alternate;
  text-shadow: 0 0 20px var(--rouge), 0 0 40px var(--rouge-glow);
}

@keyframes pulse {
  0% { text-shadow: 0 0 10px var(--rouge); }
  100% { text-shadow: 0 0 35px var(--rouge-glow); }
}

/* HEADER */
header {
  position: fixed;
  top: 0;
  width: 100%;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(12px);
  padding: 15px 25px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  z-index: 1000;
}

.logo {
  font-size: 22px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--blanc);
  text-shadow: 0 0 12px var(--rouge-glow);
}

.logo span {
  color: var(--rouge);
}

/* MENU BURGER */
.burger {
  width: 30px;
  height: 22px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  cursor: pointer;
}

.burger span {
  height: 3px;
  background: var(--blanc);
  border-radius: 5px;
  transition: 0.3s;
}

/* NAV MOBILE */
#nav-links {
  position: fixed;
  top: 70px;
  right: -100%;
  width: 60%;
  height: 100vh;
  background: #0a0a0a;
  padding: 40px 20px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  transition: 0.4s;
  border-left: 1px solid rgba(255,255,255,0.1);
}

#nav-links.open {
  right: 0;
}

#nav-links a {
  color: var(--gris);
  text-decoration: none;
  font-size: 16px;
  letter-spacing: 2px;
  text-transform: uppercase;
  transition: 0.3s;
}

#nav-links a:hover {
  color: var(--rouge);
  text-shadow: 0 0 10px var(--rouge-glow);
}

/* NAV DESKTOP */
@media (min-width: 768px) {
  .burger { display: none; }
  #nav-links {
    position: static;
    height: auto;
    width: auto;
    background: transparent;
    flex-direction: row;
    gap: 20px;
    border: none;
  }
}

/* HERO */
.hero {
  min-height: 100vh;
  background: linear-gradient(135deg, #000000, #0a0a0a);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 20px;
}

.hero h1 {
  font-size: 40px;
  text-transform: uppercase;
  letter-spacing: 4px;
  margin-bottom: 15px;
}

.hero h1 span {
  color: var(--rouge);
}

.hero p {
  font-size: 16px;
  max-width: 600px;
  margin: auto;
  opacity: 0.85;
}

.btn {
  margin-top: 25px;
  padding: 12px 28px;
  border: 1px solid var(--rouge);
  color: var(--rouge);
  background: transparent;
  text-transform: uppercase;
  letter-spacing: 3px;
  cursor: pointer;
  transition: 0.3s;
  font-size: 12px;
  border-radius: 50px;
}

.btn:hover {
  background: var(--rouge);
  color: var(--noir);
  box-shadow: 0 0 20px var(--rouge-glow);
}

/* SECTIONS */
section {
  padding: 80px 20px;
  max-width: 1100px;
  margin: auto;
}

h2 {
  font-size: 26px;
  text-transform: uppercase;
  letter-spacing: 4px;
  margin-bottom: 15px;
  text-align: center;
}

h2 span {
  color: var(--rouge);
}

.section-text {
  text-align: center;
  max-width: 800px;
  margin: auto;
  font-size: 15px;
  opacity: 0.85;
}

/* MENU */
.menu-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 25px;
  margin-top: 35px;
}

.menu-item {
  background: #0a0a0a;
  padding: 20px;
  border-radius: var(--radius);
  border: 1px solid rgba(255,255,255,0.05);
  box-shadow: 0 0 12px rgba(255,255,255,0.03);
  transition: 0.3s;
}

.menu-item:hover {
  transform: translateY(-5px);
  box-shadow: 0 0 25px var(--rouge-glow);
}

.menu-item h3 {
  margin: 0;
  font-size: 17px;
  color: var(--rouge);
  text-shadow: 0 0 10px var(--rouge-glow);
}

.menu-item p {
  font-size: 14px;
  opacity: 0.8;
}

.price {
  margin-top: 10px;
  font-size: 15px;
  color: var(--blanc);
  font-weight: bold;
}

/* GALERIE */
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 12px;
  margin-top: 25px;
}

.gallery-grid img {
  width: 100%;
  border-radius: var(--radius);
  transition: 0.3s;
}

.gallery-grid img:hover {
  transform: scale(1.05);
  box-shadow: 0 0 20px var(--rouge-glow);
}

/* FORMULAIRE */
form {
  max-width: 500px;
  margin: 25px auto 0;
}

input, textarea {
  width: 100%;
  padding: 12px;
  margin-bottom: 15px;
  border: none;
  border-radius: var(--radius);
  font-family: inherit;
  font-size: 14px;
  background: #0a0a0a;
  color: var(--blanc);
  border: 1px solid #333;
}

button[type="submit"] {
  padding: 12px 20px;
  background: var(--rouge);
  border: none;
  color: #fff;
  cursor: pointer;
  width: 100%;
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 2px;
  border-radius: 50px;
  transition: 0.3s;
}

button[type="submit"]:hover {
  background: #b62828;
  box-shadow: 0 0 20px var(--rouge-glow);
}

/* FOOTER */
footer {
  text-align: center;
  padding: 20px;
  background: #000;
  color: rgba(255,255,255,0.6);
  font-size: 12px;
  margin-top: 40px;
  border-top: 1px solid rgba(255,255,255,0.1);
}
